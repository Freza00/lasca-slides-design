# -----------------------------------------------------------------------------
# AI provider
# -----------------------------------------------------------------------------
# Lasca uses an OpenAI-compatible chat-completions endpoint. Set the gateway
# base URL + key + model. Anthropic is also supported by flipping AI_PROVIDER.

AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
# Point at any OpenAI-compatible gateway. Examples:
#   OPENAI_BASE_URL=https://api.openai.com/v1            (default OpenAI)
#   OPENAI_BASE_URL=https://your-gateway.example/v1      (any OpenAI-compatible gateway: Moonshot/Kimi, DeepSeek, vLLM, your own proxy)
# OPENAI_BASE_URL=
# AI_MODEL=                  # e.g. Kimi-K2.6, gpt-4o, etc.
# AI_CHEAP_MODEL=

# Uncomment when using Anthropic instead of OpenAI
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Auth (required for public sign-up + admin + per-user quota)
# -----------------------------------------------------------------------------
# Lasca's runtime auth is Google OAuth via Google Identity Services. The
# legacy invite-code path stays in code behind feature_flags.auth_mode and is
# off by default — see CLAUDE.md §5.16 / docs/ARCH.md.

# POSTGRES_URL=postgres://...
# JWT_SECRET=change-me
# ADMIN_SECRET=change-me
# ADMIN_EMAILS=you@example.com,teammate@example.com
# ALLOWED_ORIGINS=http://localhost:3000

# Google OAuth — same value used on client and server.
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials,
# add your origin (http://localhost:3000 for dev) to "Authorized JavaScript origins",
# then paste the Client ID here. No client secret is needed (GIS implicit flow).
# GOOGLE_CLIENT_ID=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# Registration / feedback integrations (optional)
# -----------------------------------------------------------------------------

# TURNSTILE_SECRET_KEY=
# RESEND_API_KEY=
# ADMIN_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Lemon Squeezy (optional, payment/webhook path)
# -----------------------------------------------------------------------------

# LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret
# LEMON_SQUEEZY_STORE_ID=
# LEMON_SQUEEZY_PRODUCT_ID=

# -----------------------------------------------------------------------------
# Developer-only test pages
# -----------------------------------------------------------------------------
# /harness-test, /test-laser, and /test-paged are scratch routes used while
# iterating on the AI harness, presenter overlays, and paged.js pagination.
# They return 404 in production builds unless this flag is explicitly set.
# Local dev (NODE_ENV !== 'production') always allows them.

# NEXT_PUBLIC_ENABLE_DEV_PAGES=1

