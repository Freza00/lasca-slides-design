# Dependencies
app/node_modules/
app/.pnp
app/.pnp.*
video/node_modules/

# Next.js build output
app/.next/
app/out/
app/build/
/.next/

# Remotion render output and env
video/out/
video/.env
video/.env.local
video/.remotion/

# Env files — never commit real secrets
app/.env
app/.env.local
app/.env.*.local
!app/.env.example

# TypeScript
app/*.tsbuildinfo
app/next-env.d.ts

# IDE / OS
.DS_Store
*.pem
*.swp
*.swo
.idea/
.vscode/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Claude Code session-local config (machine-specific permissions)
.claude/settings.local.json
.claude/plans/

# Local browser automation artifacts
.playwright-mcp/

# Vercel deployment config (project IDs — machine-specific)
.vercel/

# Stray root-level artifacts (any such files are noise, not source)
/tsconfig.json
/next-env.d.ts

# Local backup files (e.g. *.ts.bak left by editors / refactor sessions)
*.bak

# Maintainer-private notes — not part of the public repo.
# CLAUDE.md is a Claude Code auto-loaded context file kept locally for the
# maintainer; new contributors should read AGENTS.md and CONTRIBUTING.md.
/CLAUDE.md
/app/CLAUDE.md
/docs/internal/
